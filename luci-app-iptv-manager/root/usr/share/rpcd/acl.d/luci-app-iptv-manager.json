{
    "luci-app-iptv-manager": {
        "description": "Grant access to IPTV Manager",
        "read": {
            "uci": [ "iptv", "network", "system", "uhttpd" ],
            "ubus": {
                "file": [ "read", "exec", "stat" ],
                "luci": [ "getFeatures" ],
                "service": [ "list" ]
            }
        },
        "write": {
            "uci": [ "iptv" ],
            "ubus": {
                "file": [ "exec", "write" ],
                "service": [ "set", "start", "stop", "restart" ]
            }
        }
    }
}
